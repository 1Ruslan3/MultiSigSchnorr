@page "/audit-log"
@using MultiSigSchnorr.Contracts.Audit
@using MultiSigSchnorr.Domain.Enums
@rendermode InteractiveServer
@inject MultiSigSchnorr.Web.Services.Api.ProtocolSessionsApiClient ApiClient

<PageTitle>Audit Log</PageTitle>

<div class="audit-page">
    <div class="audit-header">
        <div>
            <h1>Audit Log</h1>
            <p class="audit-subtitle">
                Журнал ключевых событий системы: создание протокольных сессий, отзыв участников и переход между эпохами.
            </p>
        </div>

        <div class="audit-actions">
            <button class="btn btn-outline-secondary" @onclick="LoadAsync">
                Обновить
            </button>
        </div>
    </div>

    <div class="audit-filters-card">
        <div class="audit-filters-grid">
            <div class="filter-block">
                <label for="audit-search">Поиск</label>
                <input id="audit-search"
                       class="form-control"
                       @bind="_searchTerm"
                       placeholder="Текст, GUID, JSON, описание..." />
            </div>

            <div class="filter-block">
                <label for="audit-action-type">Тип действия</label>
                <select id="audit-action-type" class="form-select" @bind="_selectedActionTypeText">
                    <option value="">Все</option>
                    @foreach (var actionType in Enum.GetValues<AuditActionType>())
                    {
                        <option value="@actionType.ToString()">@actionType</option>
                    }
                </select>
            </div>

            <div class="filter-block">
                <label for="audit-entity-type">Тип сущности</label>
                <input id="audit-entity-type"
                       class="form-control"
                       @bind="_entityType"
                       placeholder="ProtocolSession / Participant / Epoch" />
            </div>

            <div class="filter-block">
                <label for="audit-entity-id">Entity ID</label>
                <input id="audit-entity-id"
                       class="form-control"
                       @bind="_entityIdText"
                       placeholder="GUID сущности" />
            </div>
        </div>

        <div class="audit-filter-actions">
            <button class="btn btn-primary" @onclick="ApplyFiltersAsync">
                Применить фильтры
            </button>

            <button class="btn btn-outline-secondary" @onclick="ResetFiltersAsync">
                Сбросить
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    @if (_items is null)
    {
        <div class="audit-card">
            <em>Загрузка аудита...</em>
        </div>
    }
    else if (_items.Count == 0)
    {
        <div class="audit-card empty">
            По текущим фильтрам журнал аудита пуст.
        </div>
    }
    else
    {
        <div class="audit-summary">
            Найдено записей: <strong>@_items.Count</strong>
        </div>

        <div class="audit-list">
            @foreach (var item in _items)
            {
                <div class="audit-card">
                    <div class="audit-card-top">
                        <div>
                            <div class="audit-title">@item.ActionType</div>
                            <div class="audit-time">@item.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</div>
                        </div>

                        <span class="audit-pill audit-@GetActionCss(item.ActionType)">
                            @item.EntityType
                        </span>
                    </div>

                    <div class="audit-description">
                        @item.Description
                    </div>

                    <div class="audit-meta-grid">
                        <div class="audit-meta-box">
                            <div class="audit-label">Entry ID</div>
                            <code>@item.Id</code>
                        </div>

                        <div class="audit-meta-box">
                            <div class="audit-label">Entity ID</div>
                            <code>@(item.EntityId?.ToString() ?? "—")</code>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(item.MetadataJson))
                    {
                        <div class="audit-json-block">
                            <div class="audit-label">Metadata JSON</div>
                            <pre>@item.MetadataJson</pre>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code
{
    private IReadOnlyList<AuditLogItemApiResponse>? _items;
    private string? _error;

    private string _searchTerm = string.Empty;
    private string _selectedActionTypeText = string.Empty;
    private string _entityType = string.Empty;
    private string _entityIdText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _error = null;

            _items = await ApiClient.GetAuditLogAsync(
                100,
                string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
                ParseActionType(),
                string.IsNullOrWhiteSpace(_entityType) ? null : _entityType,
                ParseEntityId());
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _items = Array.Empty<AuditLogItemApiResponse>();
        }
    }

    private async Task ApplyFiltersAsync()
    {
        await LoadAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _searchTerm = string.Empty;
        _selectedActionTypeText = string.Empty;
        _entityType = string.Empty;
        _entityIdText = string.Empty;

        await LoadAsync();
    }

    private AuditActionType? ParseActionType()
    {
        if (string.IsNullOrWhiteSpace(_selectedActionTypeText))
            return null;

        return Enum.TryParse<AuditActionType>(_selectedActionTypeText, out var value)
            ? value
            : null;
    }

    private Guid? ParseEntityId()
    {
        if (string.IsNullOrWhiteSpace(_entityIdText))
            return null;

        return Guid.TryParse(_entityIdText, out var value)
            ? value
            : null;
    }

    private static string GetActionCss(AuditActionType actionType) => actionType switch
    {
        AuditActionType.ProtocolSessionCreated => "session",
        AuditActionType.ParticipantRevoked => "revocation",
        AuditActionType.EpochTransitioned => "epoch",
        _ => "default"
    };
}