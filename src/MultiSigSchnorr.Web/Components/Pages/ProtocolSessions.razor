@page "/protocol-sessions"
@using Microsoft.AspNetCore.Components
@rendermode InteractiveServer
@using MultiSigSchnorr.Contracts.Diagnostics
@using MultiSigSchnorr.Contracts.ProtocolSessions
@using MultiSigSchnorr.Domain.Enums
@inject MultiSigSchnorr.Web.Services.Api.ProtocolSessionsApiClient ApiClient

<PageTitle>Protocol Sessions</PageTitle>

<div class="protocol-page">
    <div class="page-header">
        <div>
            <h1>Protocol Sessions</h1>
            <p class="page-subtitle">
                Управление коллективной подписью Шнорра: создание сессии, прохождение раундов, верификация и формирование отчёта.
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_info))
    {
        <div class="alert alert-success">@_info</div>
    }

    <div class="protocol-grid">
        <section class="left-column">
            <div class="panel-card">
                <div class="panel-card-header">
                    <h3>Seed данные</h3>
                </div>

                @if (_seed is null)
                {
                    <div class="loading-box">
                        <em>Загрузка seed-данных...</em>
                    </div>
                }
                else
                {
                    <div class="seed-meta">
                        <div><span>Epoch ID:</span> @_seed.EpochId</div>
                        <div><span>Epoch Number:</span> @_seed.EpochNumber</div>
                    </div>

                    <div class="seed-participants">
                        <h4>Участники</h4>
                        <ul>
                            @foreach (var participantId in _seed.ParticipantIds)
                            {
                                <li>@participantId</li>
                            }
                        </ul>
                    </div>

                    <div class="form-block">
                        <label for="message-input">Сообщение</label>
                        <textarea id="message-input" class="form-control protocol-textarea" @bind="_message"></textarea>
                    </div>

                    <div class="action-row">
                        <button class="btn btn-primary" @onclick="CreateSessionAsync">
                            Создать протокольную сессию
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="LoadSeedAsync">
                            Обновить seed
                        </button>
                    </div>
                }
            </div>

            <div class="panel-card">
                <div class="panel-card-header">
                    <h3>История выбранных сессий</h3>
                </div>

                @if (_sessionHistory.Count == 0)
                {
                    <div class="empty-box">Пока нет загруженных сессий.</div>
                }
                else
                {
                    <div class="history-list">
                        @foreach (var sessionId in _sessionHistory)
                        {
                            <button class="history-item @(IsCurrentSession(sessionId) ? "active" : null)"
                                    @onclick="() => LoadSessionAsync(sessionId)">
                                @sessionId
                            </button>
                        }
                    </div>
                }
            </div>
        </section>

        <section class="right-column">
            @if (_session is null)
            {
                <div class="panel-card">
                    <div class="empty-state">
                        <h3>Сессия не выбрана</h3>
                        <p>Создай новую протокольную сессию или открой её из раздела истории.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="panel-card">
                    <div class="panel-card-header">
                        <h3>Текущее состояние сессии</h3>
                        <span class="status-pill status-@GetStatusCss(_session.SessionStatus)">
                            @_session.SessionStatus
                        </span>
                    </div>

                    <div class="session-meta-grid">
                        <div class="meta-box">
                            <div class="meta-label">Session ID</div>
                            <code>@_session.SessionId</code>
                        </div>
                        <div class="meta-box">
                            <div class="meta-label">Epoch</div>
                            <div>@_session.EpochId</div>
                            <small>№ @_session.EpochNumber</small>
                        </div>
                        <div class="meta-box">
                            <div class="meta-label">Message Digest</div>
                            <code>@_session.MessageDigestHex</code>
                        </div>
                        <div class="meta-box">
                            <div class="meta-label">Aggregate Public Key</div>
                            <code>@_session.AggregatePublicKeyHex</code>
                        </div>
                    </div>
                </div>

                <div class="panel-card">
                    <div class="panel-card-header">
                        <h3>Этапы протокола</h3>
                    </div>

                    <div class="stages-grid">
                        <div class="stage-item @GetStageCss(_session.SessionStatus == SessionStatus.Created)">
                            <div class="stage-title">1. Created</div>
                            <div class="stage-desc">Сессия создана и готова к раунду commitments.</div>
                        </div>

                        <div class="stage-item @GetStageCss(_session.AllCommitmentsPublished)">
                            <div class="stage-title">2. Commitments</div>
                            <div class="stage-desc">Все участники опубликовали commitments.</div>
                        </div>

                        <div class="stage-item @GetStageCss(_session.AllNoncesRevealed)">
                            <div class="stage-title">3. Reveal Nonce</div>
                            <div class="stage-desc">Все участники раскрыли публичные nonce.</div>
                        </div>

                        <div class="stage-item @GetStageCss(_session.AllPartialSignaturesSubmitted)">
                            <div class="stage-title">4. Partial Signatures</div>
                            <div class="stage-desc">Все частичные подписи отправлены.</div>
                        </div>

                        <div class="stage-item @GetStageCss(_session.SessionStatus == SessionStatus.Completed)">
                            <div class="stage-title">5. Completed</div>
                            <div class="stage-desc">Итоговая агрегированная подпись сформирована.</div>
                        </div>
                    </div>

                    <div class="action-row mt-3">
                        <button class="btn btn-outline-secondary" @onclick="RefreshAsync">
                            Обновить состояние
                        </button>

                        <button class="btn btn-outline-dark"
                                disabled="@(_session.SessionStatus != SessionStatus.Completed)"
                                @onclick="VerifyAsync">
                            Проверить итоговую подпись
                        </button>

                        <button class="btn btn-outline-primary"
                                disabled="@(_session is null)"
                                @onclick="LoadReportAsync">
                            Сформировать отчёт
                        </button>

                        <a class="btn btn-outline-success"
                           href="@GetReportJsonUrl()"
                           target="_blank"
                           rel="noopener noreferrer">
                            Скачать JSON
                        </a>

                        <a class="btn btn-outline-success"
                           href="@GetReportTextUrl()"
                           target="_blank"
                           rel="noopener noreferrer">
                            Скачать TXT
                        </a>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_verificationMessage))
                    {
                        <div class="verification-box @(_isSignatureValid == true ? "valid" : "invalid")">
                            @_verificationMessage
                        </div>
                    }
                </div>

                <div class="panel-card">
                    <div class="panel-card-header">
                        <h3>Итоговая подпись и служебные параметры</h3>
                    </div>

                    <div class="signature-grid">
                        <div class="signature-box">
                            <div class="signature-label">Aggregate Nonce Point</div>
                            <code>@(string.IsNullOrWhiteSpace(_session.AggregateNoncePointHex) ? "—" : _session.AggregateNoncePointHex)</code>
                        </div>

                        <div class="signature-box">
                            <div class="signature-label">Challenge</div>
                            <code>@(string.IsNullOrWhiteSpace(_session.ChallengeHex) ? "—" : _session.ChallengeHex)</code>
                        </div>

                        <div class="signature-box">
                            <div class="signature-label">Aggregate Signature Nonce Point</div>
                            <code>@(string.IsNullOrWhiteSpace(_session.AggregateSignatureNoncePointHex) ? "—" : _session.AggregateSignatureNoncePointHex)</code>
                        </div>

                        <div class="signature-box">
                            <div class="signature-label">Aggregate Signature Scalar</div>
                            <code>@(string.IsNullOrWhiteSpace(_session.AggregateSignatureScalarHex) ? "—" : _session.AggregateSignatureScalarHex)</code>
                        </div>
                    </div>
                </div>

                @if (_report is not null)
                {
                    <div class="panel-card">
                        <div class="panel-card-header">
                            <h3>Отчёт по протокольной сессии</h3>
                        </div>

                        <div class="session-meta-grid">
                            <div class="meta-box">
                                <div class="meta-label">Created UTC</div>
                                <div>@_report.CreatedUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
                            </div>
                            <div class="meta-box">
                                <div class="meta-label">Completed UTC</div>
                                <div>@(_report.CompletedUtc.HasValue ? _report.CompletedUtc.Value.ToString("yyyy-MM-dd HH:mm:ss") : "—")</div>
                            </div>
                            <div class="meta-box">
                                <div class="meta-label">Status</div>
                                <div>@_report.SessionStatus</div>
                            </div>
                            <div class="meta-box">
                                <div class="meta-label">Participants Count</div>
                                <div>@_report.Participants.Count</div>
                            </div>
                        </div>

                        <div class="signature-grid mt-3">
                            <div class="signature-box">
                                <div class="signature-label">All Commitments Published</div>
                                <div>@_report.AllCommitmentsPublished</div>
                            </div>
                            <div class="signature-box">
                                <div class="signature-label">All Nonces Revealed</div>
                                <div>@_report.AllNoncesRevealed</div>
                            </div>
                            <div class="signature-box">
                                <div class="signature-label">All Partial Signatures Submitted</div>
                                <div>@_report.AllPartialSignaturesSubmitted</div>
                            </div>
                            <div class="signature-box">
                                <div class="signature-label">Aggregate Signature Scalar</div>
                                <code>@(string.IsNullOrWhiteSpace(_report.AggregateSignatureScalarHex) ? "—" : _report.AggregateSignatureScalarHex)</code>
                            </div>
                        </div>
                    </div>
                }

                <div class="panel-card">
                    <div class="panel-card-header">
                        <h3>Участники</h3>
                    </div>

                    <div class="participants-list">
                        @foreach (var participant in _session.Participants)
                        {
                            <div class="participant-card">
                                <div class="participant-header">
                                    <div>
                                        <div class="participant-name">@participant.DisplayName</div>
                                        <div class="participant-id">@participant.ParticipantId</div>
                                    </div>

                                    <div class="participant-flags">
                                        <span class="flag @(participant.HasCommitment ? "done" : null)">Commitment</span>
                                        <span class="flag @(participant.HasReveal ? "done" : null)">Reveal</span>
                                        <span class="flag @(participant.HasPartialSignature ? "done" : null)">Partial</span>
                                    </div>
                                </div>

                                <div class="participant-data-grid">
                                    <div>
                                        <div class="data-label">Public Key</div>
                                        <code>@participant.PublicKeyHex</code>
                                    </div>
                                    <div>
                                        <div class="data-label">Aggregation Coefficient</div>
                                        <code>@participant.AggregationCoefficientHex</code>
                                    </div>
                                    <div>
                                        <div class="data-label">Commitment</div>
                                        <code>@(string.IsNullOrWhiteSpace(participant.CommitmentHex) ? "—" : participant.CommitmentHex)</code>
                                    </div>
                                    <div>
                                        <div class="data-label">Public Nonce Point</div>
                                        <code>@(string.IsNullOrWhiteSpace(participant.PublicNoncePointHex) ? "—" : participant.PublicNoncePointHex)</code>
                                    </div>
                                    <div>
                                        <div class="data-label">Partial Signature</div>
                                        <code>@(string.IsNullOrWhiteSpace(participant.PartialSignatureHex) ? "—" : participant.PartialSignatureHex)</code>
                                    </div>
                                </div>

                                <div class="action-row">
                                    <button class="btn btn-sm btn-outline-primary"
                                            disabled="@(!CanPublishCommitment(participant))"
                                            @onclick="() => PublishCommitmentAsync(participant.ParticipantId)">
                                        Publish Commitment
                                    </button>

                                    <button class="btn btn-sm btn-outline-warning"
                                            disabled="@(!CanRevealNonce(participant))"
                                            @onclick="() => RevealNonceAsync(participant.ParticipantId)">
                                        Reveal Nonce
                                    </button>

                                    <button class="btn btn-sm btn-outline-success"
                                            disabled="@(!CanSubmitPartialSignature(participant))"
                                            @onclick="() => SubmitPartialSignatureAsync(participant.ParticipantId)">
                                        Submit Partial Signature
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </section>
    </div>
</div>

@code
{
    [SupplyParameterFromQuery(Name = "sessionId")]
    public Guid? QuerySessionId { get; set; }

    private DevelopmentSeedApiResponse? _seed;
    private SessionStateApiResponse? _session;
    private ProtocolSessionReportApiResponse? _report;
    private string _message = "demo-protocol-session";
    private string? _error;
    private string? _info;
    private string? _verificationMessage;
    private bool? _isSignatureValid;
    private readonly List<Guid> _sessionHistory = new();
    private Guid? _lastLoadedQuerySessionId;

    protected override async Task OnInitializedAsync()
    {
        await LoadSeedAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (QuerySessionId.HasValue && QuerySessionId != _lastLoadedQuerySessionId)
        {
            await LoadSessionAsync(QuerySessionId.Value);
            _lastLoadedQuerySessionId = QuerySessionId;
        }
    }

    private async Task LoadSeedAsync()
    {
        try
        {
            _error = null;
            _seed = await ApiClient.GetSeedAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CreateSessionAsync()
    {
        if (_seed is null)
            return;

        try
        {
            _error = null;
            _info = null;

            _session = await ApiClient.CreateProtocolSessionAsync(
                new CreateProtocolSessionApiRequest
                {
                    EpochId = _seed.EpochId,
                    ParticipantIds = _seed.ParticipantIds,
                    Message = _message
                });

            AddSessionToHistory(_session.SessionId);

            _report = null;
            _verificationMessage = null;
            _isSignatureValid = null;
            _info = "Протокольная сессия успешно создана.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadSessionAsync(Guid sessionId)
    {
        try
        {
            _error = null;
            _session = await ApiClient.GetSessionStateAsync(sessionId);
            AddSessionToHistory(sessionId);
            _report = null;
            _verificationMessage = null;
            _isSignatureValid = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RefreshAsync()
    {
        if (_session is null)
            return;

        try
        {
            _error = null;
            _session = await ApiClient.GetSessionStateAsync(_session.SessionId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LoadReportAsync()
    {
        if (_session is null)
            return;

        try
        {
            _error = null;
            _report = await ApiClient.GetSessionReportAsync(_session.SessionId);
            _info = "Отчёт по сессии успешно сформирован.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task PublishCommitmentAsync(Guid participantId)
    {
        if (_session is null)
            return;

        try
        {
            _error = null;
            _info = null;
            _session = await ApiClient.PublishCommitmentAsync(_session.SessionId, participantId);
            _report = null;
            _verificationMessage = null;
            _isSignatureValid = null;
            _info = $"Commitment опубликован для участника '{participantId}'.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RevealNonceAsync(Guid participantId)
    {
        if (_session is null)
            return;

        try
        {
            _error = null;
            _info = null;
            _session = await ApiClient.RevealNonceAsync(_session.SessionId, participantId);
            _report = null;
            _verificationMessage = null;
            _isSignatureValid = null;
            _info = $"Nonce раскрыт для участника '{participantId}'.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SubmitPartialSignatureAsync(Guid participantId)
    {
        if (_session is null)
            return;

        try
        {
            _error = null;
            _info = null;
            _session = await ApiClient.SubmitPartialSignatureAsync(_session.SessionId, participantId);
            _report = null;
            _verificationMessage = null;
            _isSignatureValid = null;
            _info = $"Частичная подпись отправлена для участника '{participantId}'.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task VerifyAsync()
    {
        if (_session is null)
            return;

        try
        {
            _error = null;
            var result = await ApiClient.VerifyProtocolSessionSignatureAsync(_session.SessionId);
            _isSignatureValid = result.IsValid;
            _verificationMessage = result.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private string GetReportJsonUrl()
        => _session is null
            ? "#"
            : ApiClient.BuildAbsoluteUrl($"api/protocol-sessions/{_session.SessionId}/report.json");

    private string GetReportTextUrl()
        => _session is null
            ? "#"
            : ApiClient.BuildAbsoluteUrl($"api/protocol-sessions/{_session.SessionId}/report.txt");

    private void AddSessionToHistory(Guid sessionId)
    {
        if (_sessionHistory.Contains(sessionId))
            return;

        _sessionHistory.Insert(0, sessionId);
    }

    private bool IsCurrentSession(Guid sessionId)
        => _session?.SessionId == sessionId;

    private static bool CanPublishCommitment(SessionParticipantStateApiResponse participant)
        => !participant.HasCommitment;

    private bool CanRevealNonce(SessionParticipantStateApiResponse participant)
        => _session is not null
           && _session.AllCommitmentsPublished
           && !participant.HasReveal;

    private bool CanSubmitPartialSignature(SessionParticipantStateApiResponse participant)
        => _session is not null
           && _session.AllNoncesRevealed
           && !participant.HasPartialSignature;

    private static string GetStatusCss(SessionStatus status) => status switch
    {
        SessionStatus.Created => "created",
        SessionStatus.CommitmentsCollection => "commitments",
        SessionStatus.NonceRevealCollection => "reveal",
        SessionStatus.PartialSignaturesCollection => "partials",
        SessionStatus.Completed => "completed",
        SessionStatus.Failed => "failed",
        SessionStatus.Cancelled => "cancelled",
        _ => "default"
    };

    private static string GetStageCss(bool isCompleted)
        => isCompleted ? "stage-done" : "stage-pending";
}